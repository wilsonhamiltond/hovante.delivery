{
  "expo": {
    "name": "Volao",
    "slug": "hovante-delivery",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ios/AppIcon.appiconset/AppIcon-1024.png",
    "scheme": "hovantedelivery",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/ios/AppIcon.appiconset/AppIcon-1024.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E8FE1",
        "foregroundImage": "./assets/android/mipmap-xxxhdpi/ic_launcher_foreground.png",
        "backgroundImage": "./assets/android/mipmap-xxxhdpi/ic_launcher_background.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/web/favicon-512x512.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Hovante Delivery usa tu ubicación para seleccionar dónde entregar tu pedido."
        }
      ]
    ]
  }
}
